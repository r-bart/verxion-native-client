{
  "expo": {
    "name": "Verxion",
    "slug": "verxion-native-client",
    "scheme": "verxion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "app.verxion.native",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "appleTeamId": "YJ37Y4TMK5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#171717"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Verxion reads your weight, workouts and steps from Apple Health to keep your training and progress in sync.",
          "NSHealthUpdateUsageDescription": "Verxion writes your logged metrics back to Apple Health.",
          "background": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "b9133391-2a6e-41fc-a8f7-03358c71114a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b9133391-2a6e-41fc-a8f7-03358c71114a"
    },
    "android": {}
  }
}
