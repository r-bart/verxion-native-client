# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/*
!.expo/types/
dist/
web-build/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Claude Code local settings
.claude/settings.local.json

# Internal/local notes (never published)
*.local.md

# test coverage
coverage/

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# EAS / native secrets (defensive)
credentials.json
google-services.json
GoogleService-Info.plist
