{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"]
  },
  "include": [
    "nativewind-env.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
