{
  // Profiles map 1:1 to the long-lived git branches (see .claude/rules/release.md):
  //   feat/* + develop → development   (integration; localhost / TODO develop-cloud API)
  //   staging          → staging       (QA on a prod-twin: the public staging API)
  //   main             → production    (store / TestFlight)
  //
  // Env vars live in each profile's `env` block (not the EAS dashboard) so builds
  // are self-contained and behave identically with `--local` and on cloud. All
  // vars are EXPO_PUBLIC_* (public client values) — safe to commit and embed in
  // the bundle. appVersionSource: local keeps the version in app.json.
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    // develop branch · LOCAL (simulator) — dev client against the API on your Mac.
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_POSTHOG_KEY": "phc_vfFyYWc9BvAzd79ZS7kN5APweyHUiYrESXzNUWF6mMbA",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com"
      },
      "channel": "development"
    },
    // develop branch · LOCAL (physical device) — dev client on a tethered iPhone.
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_POSTHOG_KEY": "phc_vfFyYWc9BvAzd79ZS7kN5APweyHUiYrESXzNUWF6mMbA",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com"
      },
      "channel": "development"
    },
    // staging branch · QA build for a physical iPhone, pointed at the public staging
    // API (HTTPS) — the prod-twin. JS bundle embedded (Release), no Metro needed.
    // Internal distribution → install via QR. This is the "independent build".
    //   eas build --profile staging --platform ios --local
    "staging": {
      "distribution": "internal",
      "autoIncrement": false,
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.rbart-dev.com",
        "EXPO_PUBLIC_POSTHOG_KEY": "phc_vfFyYWc9BvAzd79ZS7kN5APweyHUiYrESXzNUWF6mMbA",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com"
      },
      "channel": "staging"
    },
    // main branch · PRODUCTION — store / TestFlight build.
    // TODO: prod backend not provisioned yet (contracts only have develop +
    // staging). Points at staging for now — swap EXPO_PUBLIC_API_URL when the
    // production API exists.
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.rbart-dev.com",
        "EXPO_PUBLIC_POSTHOG_KEY": "phc_vfFyYWc9BvAzd79ZS7kN5APweyHUiYrESXzNUWF6mMbA",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "YJ37Y4TMK5",
        // TODO: fill when the App Store Connect app exists.
        "appleId": "TBD",
        "ascAppId": "TBD"
      }
    }
  }
}
